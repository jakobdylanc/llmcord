# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ LLM PROVIDERS - Uncomment and add your API keys as needed                   │
# └─────────────────────────────────────────────────────────────────────────────┘

# OpenAI (chat.openai.com)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter (openrouter.ai)
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (ai.google.dev)
# GOOGLE_API_KEY=your_google_api_key

# xAI (x.ai)
# XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Ollama (local) - Default is http://localhost:11434
# OLLAMA_API_HOST=http://localhost:11434
# OLLAMA_API_KEY=optional_api_key_if_set

# LM Studio (local)
# LM_STUDIO_API_HOST=http://localhost:1234

# Open WebUI (local)
# OPEN_WEBUI_API_URL=http://localhost:8080
# OPEN_WEBUI_API_KEY=your_api_key_if_set

# vLLM (local)
# VLLM_API_HOST=http://localhost:8000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ TOOLS                                                                      │
# └─────────────────────────────────────────────────────────────────────────────┘

# Brave Web Search (for web_search tool)
# Get API key: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# Yahoo Finance (for get_market_prices tool - no API key required)
# Optional: bypass paywall for some tickers
# YAHOO_FINANCE_NO_WALL_STREET_JOURNAL=1

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ AZURE SPEECH (Optional - TTS/STT for voice features)                       │
# └─────────────────────────────────────────────────────────────────────────────┘
# Get credentials: https://portal.azure.com -> Speech Services

AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus  # Your Azure region (e.g., eastus, westeurope, japaneast)
# AZURE_SPEECH_VOICE=en-US-JennyNeural  # Optional: default voice for TTS
# AZURE_SPEECH_STYLE=cheerful  # Optional: speaking style (cheerful, sad, angry, etc.)

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ OTHER SETTINGS                                                             │
# └─────────────────────────────────────────────────────────────────────────────┘

# Optional: Override config file path
# CONFIG_PATH=config.yaml

# Debug mode (optional)
# DEBUG=1

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ WEB PORTAL                                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘
PORTAL_PASSWORD=your_portal_password_here
PORTAL_DB=sqlite+aiosqlite:///data/portal.db  # Optional: custom DB path
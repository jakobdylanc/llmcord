# This gitignore is a whitelist. Inspired by https://rgbcu.be/blog/gitignore
config.yaml

# Python cache files
__pycache__/
*/__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
env/

# System environments
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

!.gitignore

!*.md
!*.py

!Dockerfile
!config-example.yaml
!docker-compose.yaml
!requirements.txt

# Ignore bot/config/tasks. But DO NOT ignore task-template.yaml
bot/config/tasks/*
!bot/config/tasks/*example.yaml

# Ignore bot/config/personas. But DO NOT ignore persona-template.md
bot/config/personas/*
!bot/config/personas/*example.md

# Google API credentials (if used)
credentials.json
token.json

# Web portal node_modules (dist should be tracked for deployment)
web/node_modules/

# Database
*.db